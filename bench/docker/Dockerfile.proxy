# bugsweep-bench egress proxy image — an nginx REVERSE proxy to the model API.
#
# This is the load-bearing egress control for the key-in-container isolation
# model. The analysis container attaches to an --internal docker network (no
# internet) and is pointed at this proxy via ANTHROPIC_BASE_URL; nginx forwards
# ONLY to https://api.anthropic.com (a hardcoded upstream) and nowhere else.
#
# Why a reverse proxy (not a CONNECT forward proxy): the `claude` CLI runs on
# Bun and does NOT honor HTTP(S)_PROXY env vars, so a forward proxy is never
# used. ANTHROPIC_BASE_URL is the SDK-level lever the CLI does honor — claude
# treats this proxy as the API endpoint. Live-validated: claude -p reaches
# Anthropic through it and gets a 200.
#
# Trade-off vs the forward-proxy design: the claude->proxy leg is plaintext on
# the private --internal network, so the proxy sees the (dedicated, revocable)
# key. That is no new exposure — the key already lives in the container — and
# egress stays hard-restricted to api.anthropic.com.
#
# proxy.sh generates and mounts the per-run nginx config at runtime.

FROM nginx:alpine

EXPOSE 8888
