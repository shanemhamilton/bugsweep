# bugsweep runtime artifacts (created inside repos it scans, never committed)
.bugsweep/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

# Node (only present if tooling is added later)
node_modules/
npm-debug.log*

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
dist/
build/
coverage/
.env
.env.local
.env.*.local
!.env.example
*.log
# BEADS runtime
.beads/beads.db
.beads/daemon.lock
.beads/daemon.pid
.beads/daemon.log
.beads/temp/
# BEADS execution state (working files for context recovery)
.beads/context/
.beads/plans/
