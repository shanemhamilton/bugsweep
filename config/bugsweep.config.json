{
  "_comment": "bugsweep configuration. Empty command strings mean auto-detect. Edit caps to bound cost/runtime on unattended runs.",
  "caps": {
    "max_iterations": 10,
    "max_runtime_minutes": 120,
    "max_fixes_per_run": 50,
    "no_progress_streak_to_stop": 2
  },
  "severity_floor": "low",
  "protected_branches": ["main", "master", "develop", "production", "prod", "release"],
  "exclude_globs": [
    "node_modules/**", "dist/**", "build/**", ".git/**", "vendor/**",
    "Pods/**", ".next/**", "coverage/**", "*.lock", "*.min.js", "**/__generated__/**"
  ],
  "adversarial": {
    "challenge_enabled": true,
    "referee_enabled": true,
    "referee_spotchecks_upheld": true
  },
  "research": {
    "antipattern_priming": true,
    "allow_web_research": false
  },
  "session": {
    "checkpoint_every_iterations": 3
  },
  "context": {
    "_comment": "Coverage-first cross-run scope. State lives in .bugsweep/state/ (gitignored). The hunt always spans the whole repo; these only reprioritize the queue.",
    "decay_factor": 0.85,
    "high_risk_top_n": 25,
    "recheck_audited_after_runs": 5,
    "variants_enabled": true,
    "variant_max_match_ratio": 0.25,
    "variant_overmatch_min_files": 2,
    "variant_retire_after_nonmatch_runs": 10
  },
  "commands": {
    "test": "",
    "build": "",
    "typecheck": "",
    "lint": ""
  }
}
