{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bugsweep/schemas/run-summary.schema.json",
  "title": "bugsweep run-summary",
  "description": "Deterministic, script-emitted reduction of a bugsweep run's ledger.jsonl + recon.json. This is the machine-readable contract a headless scheduler (nightshift) can branch on without parsing model prose. schema_version bumps on any breaking field change.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "status",
    "stop_reason",
    "coverage",
    "counts",
    "fixed",
    "quarantined",
    "confirmed_unfixed",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "mode": {
      "type": ["string", "null"]
    },
    "status": {
      "type": "string",
      "enum": ["complete", "partial", "stalled"]
    },
    "stop_reason": {
      "type": ["string", "null"]
    },
    "degraded": {
      "type": "boolean",
      "description": "True only when python3 was unavailable and the reduction fell back to grep-able ledger lines with empty findings."
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["covered", "total"],
      "properties": {
        "covered": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 0}
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical", "high", "medium", "low", "architectural"],
      "properties": {
        "critical": {"type": "integer", "minimum": 0},
        "high": {"type": "integer", "minimum": 0},
        "medium": {"type": "integer", "minimum": 0},
        "low": {"type": "integer", "minimum": 0},
        "architectural": {"type": "integer", "minimum": 0}
      }
    },
    "fixed": {
      "type": "array",
      "items": {"type": "string"}
    },
    "quarantined": {
      "type": "array",
      "items": {"type": "string"}
    },
    "confirmed_unfixed": {
      "type": "array",
      "items": {"type": "string"}
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "bug_id",
          "severity",
          "category",
          "file",
          "line",
          "fixed",
          "rationale"
        ],
        "properties": {
          "bug_id": {"type": ["string", "null"]},
          "severity": {"type": ["string", "null"]},
          "category": {"type": ["string", "null"]},
          "file": {"type": ["string", "null"]},
          "line": {"type": ["integer", "null"]},
          "fixed": {"type": "boolean"},
          "rationale": {"type": ["string", "null"]}
        }
      }
    }
  }
}
