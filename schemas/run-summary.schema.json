{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bugsweep/schemas/run-summary.schema.json",
  "title": "bugsweep run-summary",
  "description": "Deterministic, script-emitted reduction of a bugsweep run's ledger.jsonl + recon.json. This is the machine-readable contract a headless scheduler (nightshift) can branch on without parsing model prose. Versioning rule: schema_version bumps ONLY on a breaking change (a required field removed/renamed, or an existing field's meaning/type changed) — adding a new OPTIONAL field, such as root_cause_clusters/follow_up/flaky (bugsweep-xdw), is backward compatible and does NOT bump schema_version.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "status",
    "stop_reason",
    "coverage",
    "counts",
    "fixed",
    "quarantined",
    "confirmed_unfixed",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "mode": {
      "type": ["string", "null"]
    },
    "status": {
      "type": "string",
      "enum": ["complete", "partial", "stalled"]
    },
    "stop_reason": {
      "type": ["string", "null"]
    },
    "degraded": {
      "type": "boolean",
      "description": "True only when python3 was unavailable and the reduction fell back to grep-able ledger lines with empty findings."
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["covered", "total"],
      "properties": {
        "covered": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 0}
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical", "high", "medium", "low", "architectural"],
      "properties": {
        "critical": {"type": "integer", "minimum": 0},
        "high": {"type": "integer", "minimum": 0},
        "medium": {"type": "integer", "minimum": 0},
        "low": {"type": "integer", "minimum": 0},
        "architectural": {"type": "integer", "minimum": 0}
      }
    },
    "fixed": {
      "type": "array",
      "items": {"type": "string"}
    },
    "quarantined": {
      "type": "array",
      "items": {"type": "string"}
    },
    "confirmed_unfixed": {
      "type": "array",
      "items": {"type": "string"}
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "bug_id",
          "severity",
          "category",
          "file",
          "line",
          "fixed",
          "rationale"
        ],
        "properties": {
          "bug_id": {"type": ["string", "null"]},
          "severity": {"type": ["string", "null"]},
          "category": {"type": ["string", "null"]},
          "file": {"type": ["string", "null"]},
          "line": {"type": ["integer", "null"]},
          "fixed": {"type": "boolean"},
          "rationale": {"type": ["string", "null"]},
          "vote_split": {
            "type": "object",
            "description": "OPTIONAL (bugsweep-hcj). Present only for severity >= high/critical findings for which the Referee recorded K independent-adjudication referee_vote ledger events (see prompts/referee.md and bench/scorer/run_summary.py's majority_gate). Absent for medium/low findings (single-pass, unchanged) and for high/critical findings with no recorded votes.",
            "additionalProperties": false,
            "required": ["confirmed", "total", "eligible"],
            "properties": {
              "confirmed": {"type": "integer", "minimum": 0},
              "total": {"type": "integer", "minimum": 0},
              "eligible": {"type": "boolean"}
            }
          },
          "repro": {
            "type": "string",
            "enum": ["none", "unreproduced", "confirmed", "failed"],
            "description": "OPTIONAL (bugsweep-hty). The repro gate's outcome for this finding, from scripts/repro.sh's repro_status ledger events: 'none' — no repro command was available (no framework detected, or the bug's shape isn't reproducible as a minimal test); 'unreproduced' — a repro was attempted but did NOT fail before the fix, so it never demonstrated the bug (falls back to suite-only gating, exactly like 'none'); 'confirmed' — the repro FAILED before the fix and PASSED after it (only ever seen on a fixed finding); 'failed' — the repro was still RED after the fix, meaning the fix was reverted and quarantined (only ever seen on a quarantined finding). Always present on every finding reduce_run emits (defaults to 'none'), but NOT in `required` so older run-summary.json producers/consumers stay schema-valid without it."
          }
        }
      }
    },
    "root_cause_clusters": {
      "type": "array",
      "description": "OPTIONAL (bugsweep-xdw). Confirmed/fixed findings sharing a category (or category::variant) cluster together; a singleton (size 1) is not a cluster and is excluded. Ordered size descending, then cluster name ascending.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cluster", "size", "representative", "files"],
        "properties": {
          "cluster": {"type": "string"},
          "size": {"type": "integer", "minimum": 2},
          "representative": {"type": ["string", "null"]},
          "files": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "follow_up": {
      "type": "array",
      "description": "OPTIONAL (bugsweep-xdw). The 'where to look next' handoff, derived from recon.json's uncovered batches, prior-coverage.json's high-risk/stale files, and this run's quarantined findings. Ordered uncovered_batch -> high_risk_file -> stale_file -> quarantined, capped at FOLLOW_UP_CAP entries (see bench/scorer/run_summary.py).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "ref"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["uncovered_batch", "stale_file", "high_risk_file", "quarantined"]
          },
          "ref": {"type": "string"},
          "detail": {"type": ["string", "null"]}
        }
      }
    },
    "flaky": {
      "type": "array",
      "description": "OPTIONAL (bugsweep-xdw). One entry per flaky_test ledger event emitted by the test-runner instrumentation; empty when no such events exist.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["test", "file", "reruns", "failures"],
        "properties": {
          "test": {"type": ["string", "null"]},
          "file": {"type": ["string", "null"]},
          "reruns": {"type": ["integer", "null"]},
          "failures": {"type": ["integer", "null"]}
        }
      }
    },
    "priority": {
      "type": "object",
      "description": "OPTIONAL deterministic why-now report emitted by the full Python reducer. Application counts come from priority-application.json and target outcomes require explicit attribution or verified audit coverage; degraded summaries may omit this object.",
      "additionalProperties": false,
      "required": ["available", "degraded_reason", "application_available", "application_reason", "top_targets", "signal_health", "unmapped_focus_signals", "signal_yield", "application"],
      "properties": {
        "available": {"type": "boolean"},
        "degraded_reason": {
          "type": ["string", "null"],
          "maxLength": 80,
          "description": "Null for a validated priority artifact; otherwise the bounded reason priority context was missing, invalid, or degraded."
        },
        "application_available": {"type": "boolean"},
        "application_reason": {
          "type": ["string", "null"],
          "maxLength": 80,
          "description": "Null only when priority-application.json passed its deterministic receipt checks; otherwise why applied counts are unavailable."
        },
        "top_targets": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["file", "lane", "priority_score", "reason_codes", "investigated", "outcome"],
            "properties": {
              "file": {"type": "string"},
              "lane": {"type": "string", "enum": ["must_focus", "high", "elevated", "normal"]},
              "priority_score": {"type": "integer", "minimum": 0, "maximum": 100},
              "reason_codes": {"type": "array", "maxItems": 20, "items": {"type": "string"}, "uniqueItems": true},
              "investigated": {"type": "boolean"},
              "outcome": {"type": "string", "enum": ["confirmed", "rejected", "no_finding", "unattributed", "not_reviewed"]}
            }
          }
        },
        "signal_health": {
          "type": "object",
          "additionalProperties": false,
          "required": ["accepted", "expired", "inactive", "malformed", "unmapped", "overmatched"],
          "properties": {
            "accepted": {"type": "integer", "minimum": 0},
            "expired": {"type": "integer", "minimum": 0},
            "inactive": {"type": "integer", "minimum": 0},
            "malformed": {"type": "integer", "minimum": 0},
            "unmapped": {"type": "integer", "minimum": 0},
            "overmatched": {"type": "integer", "minimum": 0}
          }
        },
        "unmapped_focus_signals": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "source", "kind", "severity", "component", "flow"],
            "properties": {
              "id": {"type": "string", "maxLength": 80},
              "source": {"type": "string", "maxLength": 80},
              "kind": {"type": "string", "maxLength": 80},
              "severity": {"type": "string", "maxLength": 80},
              "component": {"type": "string", "maxLength": 80},
              "flow": {"type": "string", "maxLength": 80}
            }
          }
        },
        "signal_yield": {
          "type": "array",
          "maxItems": 50,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["reason", "observed", "investigated", "attributed", "confirmed", "rejected", "no_finding", "unattributed", "confirmation_rate"],
            "properties": {
              "reason": {"type": "string", "maxLength": 80},
              "observed": {"type": "integer", "minimum": 0},
              "investigated": {"type": "integer", "minimum": 0},
              "attributed": {"type": "integer", "minimum": 0},
              "confirmed": {"type": "integer", "minimum": 0},
              "rejected": {"type": "integer", "minimum": 0},
              "no_finding": {"type": "integer", "minimum": 0},
              "unattributed": {"type": "integer", "minimum": 0},
              "confirmation_rate": {"type": "number", "minimum": 0, "maximum": 1}
            }
          }
        },
        "application": {
          "type": "object",
          "additionalProperties": false,
          "required": ["candidate_count", "promoted_batches", "promoted_batch_count", "added_file_count", "already_in_budget_count", "skipped_candidate_count"],
          "properties": {
            "candidate_count": {"type": "integer", "minimum": 0, "maximum": 200},
            "promoted_batches": {"type": "array", "maxItems": 20, "items": {"type": "string"}, "uniqueItems": true},
            "promoted_batch_count": {"type": "integer", "minimum": 0, "maximum": 20},
            "added_file_count": {"type": "integer", "minimum": 0, "maximum": 1000},
            "already_in_budget_count": {"type": "integer", "minimum": 0, "maximum": 200},
            "skipped_candidate_count": {"type": "integer", "minimum": 0, "maximum": 200}
          }
        }
      }
    },
    "near_misses": {
      "type": "array",
      "description": "OPTIONAL (bugsweep-dxh, --recall mode). Referee near-miss verdicts (confidence 50-67 — genuinely plausible but not >67% CONFIRMED) surfaced for human review. Populated ONLY when reduce_run's 'recall' parameter is true (see bench/scorer/run_summary.py); empty otherwise, even if near_miss ledger events exist. This field is reporting-only: near-misses are NEVER eligible for auto-fix and never appear in fixed/quarantined/confirmed_unfixed/findings, regardless of recall.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["bug_id", "severity", "category", "file", "line", "rationale", "confidence"],
        "properties": {
          "bug_id": {"type": ["string", "null"]},
          "severity": {"type": ["string", "null"]},
          "category": {"type": ["string", "null"]},
          "file": {"type": ["string", "null"]},
          "line": {"type": ["integer", "null"]},
          "rationale": {"type": ["string", "null"]},
          "confidence": {"type": ["integer", "null"], "minimum": 0, "maximum": 100}
        }
      }
    }
  }
}
